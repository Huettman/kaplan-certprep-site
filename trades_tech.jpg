/* ═══════════════════════════════════════════════════════════════
   KAPLAN CERTPREP — Main Stylesheet
   Brand: Kaplan Purple #240F6E | Merriweather + Open Sans
   ═══════════════════════════════════════════════════════════════ */

@import url('https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700&family=Open+Sans:wght@400;600;700&display=swap');

/* ─── BRAND TOKENS ──────────────────────────────────────────── */
:root {
  --purple: #240F6E;
  --purple-s1: #503F8B;
  --purple-s2: #7C6CA7;
  --purple-s3: #A79FC5;
  --blue: #005DE8;
  --green: #287D21;
  --yellow: #FFC82E;
  --red: #D6083B;
  --pink: #DE1B90;
  --dark: #212121;
  --med: #4A4A4A;
  --grey: #A0A0A0;
  --light-grey: #D9D9D9;
  --lighter-grey: #EFEFEF;
  --white: #fff;
  --font-heading: 'Merriweather', Georgia, serif;
  --font-body: 'Open Sans', Arial, sans-serif;
}

/* ─── RESET & BASE ──────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: var(--font-body);
  color: var(--med);
  background: var(--lighter-grey);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

img { max-width: 100%; height: auto; display: block; }
a { color: var(--purple); text-decoration: none; transition: color .3s; }
a:hover { color: var(--blue); }

h1, h2, h3, h4 {
  font-family: var(--font-heading);
  color: var(--dark);
  line-height: 1.15;
}

/* ─── LAYOUT ────────────────────────────────────────────────── */
.container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
.container--narrow { max-width: 800px; margin: 0 auto; padding: 0 24px; }
.container--mid { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

/* ─── NAV ───────────────────────────────────────────────────── */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: var(--purple);
  padding: 0 24px;
  transition: background .3s, box-shadow .3s;
}
.nav--scrolled {
  background: rgba(36,15,110,.95);
  backdrop-filter: blur(10px);
  box-shadow: 0 2px 20px rgba(0,0,0,.15);
}
.nav__inner {
  max-width: 1200px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between;
  height: 64px;
}
.nav__logo img { height: 28px; width: auto; }
.nav__links { display: flex; gap: 32px; list-style: none; }
.nav__links a {
  color: rgba(255,255,255,.7); font-size: 14px; font-weight: 600;
  text-decoration: none; transition: color .3s;
}
.nav__links a:hover, .nav__links a.active { color: #fff; }
.nav__mobile { display: none; background: none; border: none; color: #fff; font-size: 24px; cursor: pointer; }

/* ─── HERO ──────────────────────────────────────────────────── */
.hero {
  padding: 100px 24px 0;
  background: linear-gradient(135deg, var(--purple) 0%, var(--purple-s1) 100%);
  position: relative; overflow: hidden;
}
.hero__grid {
  max-width: 1200px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center;
}
.hero__text { padding: 0 0 80px; }
.hero__title {
  font-size: clamp(30px, 4.5vw, 50px); font-weight: 300;
  color: #fff; line-height: 1.12; margin: 0 0 20px;
}
.hero__title strong { font-weight: 700; }
.hero__subtitle {
  font-size: 17px; color: rgba(255,255,255,.75);
  line-height: 1.7; max-width: 440px; margin: 0 0 32px;
}
.hero__subtitle strong { color: #fff; }
.hero__actions { display: flex; gap: 14px; flex-wrap: wrap; }
.hero__accent {
  position: absolute; bottom: 0; left: 0; right: 0; height: 4px;
  background: linear-gradient(90deg, var(--blue), var(--purple), var(--pink));
}

/* Hero photo mosaic */
.hero__photos { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 0 0 40px; }
.hero__photo {
  border-radius: 14px; overflow: hidden; aspect-ratio: 1;
  box-shadow: 0 8px 32px rgba(0,0,0,.25);
}
.hero__photo img { width: 100%; height: 100%; object-fit: cover; }
.hero__photo:nth-child(2) { margin-top: 30px; }
.hero__photo:nth-child(3) { margin-top: -20px; }
.hero__photo:nth-child(4) { margin-top: 10px; }

/* ─── BUTTONS ───────────────────────────────────────────────── */
.btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 12px 28px; border-radius: 10px;
  font-size: 14px; font-weight: 700; font-family: var(--font-body);
  cursor: pointer; transition: all .3s; border: 2px solid transparent;
  text-decoration: none;
}
.btn--primary {
  background: var(--yellow); color: var(--dark); border-color: var(--yellow);
}
.btn--primary:hover { background: #e6b400; border-color: #e6b400; transform: translateY(-2px); }
.btn--ghost {
  background: transparent; color: #fff; border: 2px solid rgba(255,255,255,.3);
}
.btn--ghost:hover { border-color: #fff; color: #fff; }
.btn--purple {
  background: var(--purple); color: #fff; border-color: var(--purple);
}
.btn--purple:hover { background: var(--purple-s1); transform: translateY(-2px); }

/* ─── SECTION TITLES ────────────────────────────────────────── */
.section-title {
  font-size: clamp(22px, 3.5vw, 32px); font-weight: 300;
  text-align: center; margin: 0 0 8px;
}
.section-title strong { font-weight: 700; color: var(--purple); }
.section-subtitle {
  font-size: 15px; color: var(--med); text-align: center; margin: 0 0 40px;
}

/* ─── CATEGORY CARDS ────────────────────────────────────────── */
.cat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 16px; }
.cat-card {
  background: #fff; border: 1px solid var(--light-grey); border-radius: 16px;
  padding: 28px 20px; text-align: center; cursor: pointer;
  transition: all .3s; text-decoration: none; display: block;
}
.cat-card:hover {
  transform: translateY(-4px); box-shadow: 0 8px 24px rgba(36,15,110,.1);
  border-color: var(--purple-s3);
}
.cat-card__icon { font-size: 32px; margin-bottom: 12px; }
.cat-card__title {
  font-size: 15px; font-weight: 700; color: var(--dark);
  font-family: var(--font-heading); margin: 0 0 4px;
}
.cat-card__count { font-size: 12px; color: var(--grey); font-weight: 600; text-transform: uppercase; letter-spacing: .5px; }

/* ─── WHY CERTPREP ──────────────────────────────────────────── */
.why-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center;
}
.why-image { border-radius: 20px; overflow: hidden; box-shadow: 0 12px 40px rgba(36,15,110,.12); position: relative; }
.why-image img { width: 100%; display: block; aspect-ratio: 4/3; object-fit: cover; }
.why-image__accent { position: absolute; bottom: 0; left: 0; right: 0; height: 4px; background: var(--purple); }
.why-props { display: flex; flex-direction: column; gap: 24px; }
.why-prop { display: flex; gap: 16px; align-items: flex-start; }
.why-prop__icon {
  width: 48px; height: 48px; border-radius: 12px;
  background: rgba(36,15,110,.06); display: flex; align-items: center;
  justify-content: center; font-size: 22px; flex-shrink: 0;
}
.why-prop__title { font-size: 16px; font-weight: 700; color: var(--dark); font-family: var(--font-heading); margin: 0 0 4px; }
.why-prop__desc { font-size: 14px; color: var(--med); line-height: 1.6; margin: 0; }

/* ─── HOW IT WORKS ──────────────────────────────────────────── */
.steps { display: flex; flex-direction: column; gap: 20px; max-width: 900px; margin: 0 auto; }
.step {
  display: flex; gap: 20px; align-items: flex-start;
  background: #fff; border: 1px solid var(--light-grey); border-radius: 16px; padding: 24px;
}
.step__num { font-size: 28px; font-weight: 300; color: var(--purple); font-family: var(--font-heading); flex-shrink: 0; }
.step__content { border-left: 2px solid var(--purple-s3); padding-left: 20px; }
.step__title { font-size: 17px; font-weight: 700; color: var(--dark); font-family: var(--font-heading); margin: 0 0 4px; }
.step__desc { font-size: 14px; color: var(--med); line-height: 1.6; margin: 0; }

/* ─── FAQ ───────────────────────────────────────────────────── */
.faq-item { border-bottom: 1px solid var(--light-grey); background: #fff; margin-bottom: 4px; }
.faq-item.open { border-radius: 12px; }
.faq-toggle {
  width: 100%; background: none; border: none; color: var(--dark);
  font-size: 15px; font-weight: 600; font-family: var(--font-body);
  padding: 18px 20px; cursor: pointer; display: flex;
  justify-content: space-between; align-items: center; text-align: left;
}
.faq-toggle__icon { font-size: 20px; color: var(--purple); transition: transform .3s; }
.faq-item.open .faq-toggle__icon { transform: rotate(45deg); }
.faq-body { max-height: 0; overflow: hidden; transition: max-height .4s ease; }
.faq-item.open .faq-body { max-height: 200px; }
.faq-body p { font-size: 14px; color: var(--med); line-height: 1.7; padding: 0 20px 18px; margin: 0; }

/* ─── CTA BANNER ────────────────────────────────────────────── */
.cta-banner {
  max-width: 900px; margin: 0 auto; border-radius: 20px;
  overflow: hidden; position: relative;
}
.cta-banner__bg { position: absolute; inset: 0; }
.cta-banner__bg img { width: 100%; height: 100%; object-fit: cover; }
.cta-banner__overlay {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(36,15,110,.93) 0%, rgba(80,63,139,.87) 100%);
}
.cta-banner__content { position: relative; padding: 56px 36px; text-align: center; }
.cta-banner__accent { position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, var(--blue), var(--yellow), var(--pink)); }
.cta-banner__title { font-size: clamp(22px,3.5vw,32px); font-weight: 300; color: #fff; margin: 0 0 12px; font-family: var(--font-heading); }
.cta-banner__title strong { font-weight: 700; }
.cta-banner__desc { font-size: 15px; color: rgba(255,255,255,.7); margin: 0 0 28px; }

/* ─── FOOTER ────────────────────────────────────────────────── */
.footer { background: var(--purple); padding: 40px 24px 28px; }
.footer__inner {
  max-width: 1200px; margin: 0 auto;
  display: flex; justify-content: space-between; align-items: center;
  flex-wrap: wrap; gap: 16px;
}
.footer__logo img { height: 22px; width: auto; }
.footer__links { display: flex; gap: 24px; }
.footer__links a { font-size: 13px; color: rgba(255,255,255,.55); text-decoration: none; }
.footer__links a:hover { color: #fff; }
.footer__disclaimer {
  max-width: 1200px; margin: 16px auto 0; text-align: center;
  font-size: 11px; color: rgba(255,255,255,.35); font-style: italic;
}
.footer__copyright {
  max-width: 1200px; margin: 8px auto 0; text-align: center;
  font-size: 12px; color: rgba(255,255,255,.3);
}

/* ─── PRODUCT CARDS ─────────────────────────────────────────── */
.product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
.product-card {
  background: #fff; border: 1px solid var(--light-grey); border-radius: 16px;
  overflow: hidden; cursor: pointer; transition: all .3s; text-decoration: none; display: block;
}
.product-card:hover {
  transform: translateY(-4px); box-shadow: 0 8px 24px rgba(36,15,110,.1);
  border-color: var(--purple-s3);
}
.product-card__accent { height: 4px; }
.product-card__body { padding: 24px; }
.product-card__icon { font-size: 28px; margin-bottom: 12px; }
.product-card__title { font-size: 16px; font-weight: 700; color: var(--dark); font-family: var(--font-heading); margin: 0 0 8px; }
.product-card__desc { font-size: 13px; color: var(--med); line-height: 1.5; margin: 0 0 16px; }
.product-card__meta { display: flex; justify-content: space-between; align-items: center; }
.product-card__questions { font-size: 12px; color: var(--grey); font-weight: 600; }
.product-card__price { font-size: 18px; font-weight: 700; color: var(--purple); font-family: var(--font-heading); }
.product-card__old-price { font-size: 13px; color: var(--grey); text-decoration: line-through; margin-left: 8px; }

/* ─── BLOG CARDS ────────────────────────────────────────────── */
.blog-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; }
.blog-card {
  background: #fff; border: 1px solid var(--light-grey); border-radius: 16px;
  padding: 24px; cursor: pointer; transition: all .3s; text-decoration: none; display: block;
}
.blog-card:hover {
  transform: translateY(-4px); box-shadow: 0 8px 24px rgba(36,15,110,.1);
  border-color: var(--purple-s3);
}
.blog-card__cat {
  display: inline-block; font-size: 11px; font-weight: 700;
  text-transform: uppercase; letter-spacing: .5px;
  padding: 3px 10px; border-radius: 100px; margin-bottom: 12px;
}
.blog-card__cat--cdl { background: rgba(0,93,232,.1); color: var(--blue); }
.blog-card__cat--hr { background: rgba(40,125,33,.1); color: var(--green); }
.blog-card__cat--trades { background: rgba(214,8,59,.1); color: var(--red); }
.blog-card__title { font-size: 16px; font-weight: 700; color: var(--dark); font-family: var(--font-heading); margin: 0 0 8px; line-height: 1.3; }
.blog-card__excerpt { font-size: 13px; color: var(--med); line-height: 1.5; margin: 0 0 16px; }
.blog-card__meta { font-size: 12px; color: var(--grey); }

/* ─── BLOG DETAIL ───────────────────────────────────────────── */
.article { max-width: 720px; }
.article h2 { font-size: 22px; font-weight: 700; color: var(--dark); margin: 32px 0 12px; }
.article p { font-size: 15px; color: var(--med); line-height: 1.8; margin: 0 0 16px; }

/* ─── CATEGORY HERO ─────────────────────────────────────────── */
.cat-hero {
  padding: 120px 24px 70px; position: relative; overflow: hidden;
  background: linear-gradient(135deg, var(--purple) 0%, var(--purple-s1) 100%);
}
.cat-hero__grid {
  max-width: 1100px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 320px; gap: 40px; align-items: center;
}
.cat-hero__grid--centered { display: block; max-width: 800px; margin: 0 auto; text-align: center; }
.cat-hero__back { color: rgba(255,255,255,.7); font-size: 13px; font-weight: 600; display: inline-block; margin-bottom: 24px; }
.cat-hero__badge {
  display: inline-flex; align-items: center; gap: 10px;
  background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.2);
  border-radius: 100px; padding: 8px 20px 8px 14px; margin-bottom: 24px;
}
.cat-hero__badge-icon { font-size: 22px; }
.cat-hero__badge-text { font-size: 13px; font-weight: 600; color: #fff; }
.cat-hero__title { font-size: clamp(30px,5vw,48px); font-weight: 300; color: #fff; margin: 0 0 16px; }
.cat-hero__title strong { font-weight: 700; }
.cat-hero__subtitle { font-size: 16px; color: rgba(255,255,255,.75); line-height: 1.7; max-width: 560px; margin: 0 0 32px; }
.cat-hero__stats { display: flex; gap: 40px; flex-wrap: wrap; }
.cat-hero__stat-num { font-size: 24px; font-weight: 300; color: #fff; font-family: var(--font-heading); }
.cat-hero__stat-label { font-size: 12px; color: rgba(255,255,255,.6); font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
.cat-hero__image { border-radius: 18px; overflow: hidden; box-shadow: 0 12px 40px rgba(0,0,0,.3); }
.cat-hero__image img { width: 100%; display: block; aspect-ratio: 3/4; object-fit: cover; object-position: top; }

/* ─── FILTER CHIPS ──────────────────────────────────────────── */
.filters { display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; padding: 24px 0; }
.filter-chip {
  background: #fff; border: 1.5px solid var(--light-grey); color: var(--med);
  border-radius: 100px; padding: 8px 20px; font-size: 13px; font-weight: 600;
  cursor: pointer; transition: all .3s; font-family: var(--font-body);
}
.filter-chip:hover { border-color: var(--purple-s3); }
.filter-chip.active { background: var(--purple); border-color: var(--purple); color: #fff; }

/* ─── PAGINATION ────────────────────────────────────────────── */
.pagination { display: flex; gap: 6px; justify-content: center; align-items: center; flex-wrap: wrap; }
.pagination__btn {
  padding: 8px 14px; border-radius: 8px; background: #fff;
  border: 1px solid var(--light-grey); color: var(--med);
  font-size: 13px; font-weight: 600; cursor: pointer; font-family: var(--font-body);
}
.pagination__btn.active { background: var(--purple); border-color: var(--purple); color: #fff; }
.pagination__info { font-size: 13px; color: var(--grey); margin-top: 12px; }

/* ─── CONTACT FORM ──────────────────────────────────────────── */
.form-group { margin-bottom: 20px; }
.form-group label { display: block; font-size: 13px; font-weight: 600; color: var(--dark); margin-bottom: 6px; }
.form-group input, .form-group textarea, .form-group select {
  width: 100%; padding: 12px 16px; border: 1.5px solid var(--light-grey);
  border-radius: 10px; font-size: 14px; font-family: var(--font-body);
  transition: border-color .3s; outline: none;
}
.form-group input:focus, .form-group textarea:focus, .form-group select:focus { border-color: var(--purple); }

/* ─── SIDEBAR CTA ───────────────────────────────────────────── */
.sidebar-cta {
  background: var(--purple); border-radius: 16px; padding: 28px;
  color: #fff; position: sticky; top: 88px;
}
.sidebar-cta__title { font-size: 18px; font-weight: 700; margin: 0 0 8px; font-family: var(--font-heading); }
.sidebar-cta__desc { font-size: 13px; color: rgba(255,255,255,.7); margin: 0 0 20px; line-height: 1.5; }

/* ─── UTILITIES ─────────────────────────────────────────────── */
.text-center { text-align: center; }
.bg-light { background: var(--lighter-grey); }
.bg-white { background: #fff; }
.section-padding { padding: 60px 24px; }
.section-padding--lg { padding: 70px 24px; }

/* ─── RESPONSIVE ────────────────────────────────────────────── */
@media (max-width: 768px) {
  .hero__grid { grid-template-columns: 1fr; }
  .hero__photos { display: none; }
  .hero__text { padding: 0 0 60px; text-align: center; }
  .hero__actions { justify-content: center; }
  .why-grid { grid-template-columns: 1fr; }
  .why-image { display: none; }
  .cat-hero__grid { grid-template-columns: 1fr; }
  .cat-hero__image { display: none; }
  .nav__links { display: none; }
  .nav__mobile { display: block; }
  .product-grid { grid-template-columns: 1fr; }
  .blog-grid { grid-template-columns: 1fr; }
  .footer__inner { flex-direction: column; text-align: center; }
}
